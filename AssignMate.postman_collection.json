    {
      "name": "Courses",
      "item": [
        {
          "name": "List Courses",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/courses/"
          }
        },
        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/courses/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Course 1\",\n  \"description\": \"Intro course\",\n  \"grading_scale\": {\"A\": 90, \"B\": 80}\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('course_id', json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Course",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/courses/{{course_id}}/"
          }
        },
        {
          "name": "Update Course (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/courses/{{course_id}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Delete Course",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/courses/{{course_id}}/"
          }
        },
        {
          "name": "Generate Invite Code",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/courses/{{course_id}}/invite-code/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('invite_code', json.invite_code);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Join Course",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
